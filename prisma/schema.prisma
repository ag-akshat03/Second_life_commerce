generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  PAYPAL
  COD
}

enum NotificationType {
  ORDER
  PROMO
  SECURITY
  SYSTEM
}

model User {
  id                     String                 @id @default(auto()) @map("_id") @db.ObjectId
  name                   String?
  email                  String?                @unique
  emailVerified          DateTime?
  image                  String?
  password               String?
  phone                  String?
  role                   Role                   @default(USER)
  isPrime                Boolean                @default(false)
  primeExpiresAt         DateTime?
  isBanned               Boolean                @default(false)
  accounts               Account[]
  sessions               Session[]
  addresses              Address[]
  orders                 Order[]
  reviews                Review[]
  cartItems              CartItem[]
  wishlistItems          WishlistItem[]
  savedForLater          SavedForLater[]
  notifications          Notification[]
  payments               Payment[]
  searchHistory          SearchHistory[]
  // Second Life Commerce relations
  greenCredits           GreenCreditsLedger[]
  digitalInventoryOwned  DigitalInventoryItem[] @relation("DigitalInventoryOriginalOwner")
  digitalInventoryBought DigitalInventoryItem[] @relation("DigitalInventoryMatchedBuyer")
  resaleListingsSelling  ResaleListing[]        @relation("ResaleListingSeller")
  resaleListingsBuying   ResaleListing[]        @relation("ResaleListingBuyer")
  sellerTrustScore       SellerTrustScore?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String     @unique
  slug      String     @unique
  image     String?
  parentId  String?    @db.ObjectId
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
}

model Product {
  id                    String                 @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  slug                  String                 @unique
  brand                 String
  category              String
  description           String
  specifications        Json?
  images                String[]
  price                 Float
  mrp                   Float
  discount              Int
  stock                 Int
  rating                Float                  @default(0)
  reviewCount           Int                    @default(0)
  tags                  String[]
  isPrime               Boolean                @default(true)
  isFeatured            Boolean                @default(false)
  isSponsored           Boolean                @default(false)
  isFlashDeal           Boolean                @default(false)
  flashEndsAt           DateTime?
  seller                String                 @default("Amazon Fulfilment India")
  warranty              String?
  reviews               Review[]
  orderItems            OrderItem[]
  cartItems             CartItem[]
  wishlistedBy          WishlistItem[]
  savedForLater         SavedForLater[]
  // Second Life Commerce relations
  healthCards           ProductHealthCard[]
  digitalInventoryItems DigitalInventoryItem[]
  resaleListings        ResaleListing[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Review {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  productId        String   @db.ObjectId
  rating           Int
  title            String
  comment          String
  images           String[] @default([])
  helpfulVotes     Int      @default(0)
  verifiedPurchase Boolean  @default(false)
  reply            String?
  user             User     @relation(fields: [userId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])
  createdAt        DateTime @default(now())
}

model Address {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String   @default("India")
  isDefault Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model SavedForLater {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Coupon {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  code        String    @unique
  description String
  discountPct Int?
  discountAmt Float?
  minOrder    Float     @default(0)
  maxUses     Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model Order {
  id                    String          @id @default(auto()) @map("_id") @db.ObjectId
  userId                String          @db.ObjectId
  user                  User            @relation(fields: [userId], references: [id])
  items                 OrderItem[]
  timeline              OrderTimeline[]
  status                OrderStatus     @default(PENDING)
  paymentStatus         PaymentStatus   @default(PENDING)
  paymentProvider       PaymentProvider @default(STRIPE)
  couponCode            String?
  stripeCheckoutSession String?
  stripePaymentIntent   String?
  subtotal              Float
  shipping              Float
  tax                   Float
  discount              Float           @default(0)
  total                 Float
  shippingFullName      String
  shippingPhone         String
  shippingLine1         String
  shippingLine2         String?
  shippingCity          String
  shippingState         String
  shippingPincode       String
  shippingCountry       String          @default("India")
  deliveryMethod        String          @default("standard")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model OrderTimeline {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String      @db.ObjectId
  status    OrderStatus
  message   String
  order     Order       @relation(fields: [orderId], references: [id])
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String  @db.ObjectId
  productId String  @db.ObjectId
  title     String
  image     String
  price     Float
  quantity  Int
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Payment {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  userId     String          @db.ObjectId
  orderId    String?         @db.ObjectId
  provider   PaymentProvider
  amount     Float
  status     PaymentStatus   @default(PENDING)
  externalId String?
  user       User            @relation(fields: [userId], references: [id])
  createdAt  DateTime        @default(now())
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  read      Boolean          @default(false)
  link      String?
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
}

model SearchHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  query     String
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// ============================================================
// SECOND LIFE COMMERCE — AI-Driven Sustainable Returns & Resale
// Models per PRD Sections 27-39
// ============================================================

enum ConditionTier {
  LIKE_NEW // Cosmetic 90-100
  GOOD // Cosmetic 75-89
  ACCEPTABLE // Cosmetic 60-74
  POOR // Below 60 / functional issues
}

enum DigitalInventoryStatus {
  NONE
  AVAILABLE
  MATCHED
  IN_TRANSIT
  EXPIRED
}

enum ResaleListingStatus {
  PENDING_VERIFICATION
  LISTED
  SOLD
  DECLINED
  EXPIRED
}

enum GreenCreditTransactionType {
  DONATION
  RECYCLING
  P2P_RESALE
  REDEMPTION
  BONUS
}

// Module 1 — Product Health Card (PHC)
// Stores AI-generated condition grading results from DINOv2 + CLIP pipeline
model ProductHealthCard {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  productId            String        @db.ObjectId
  orderId              String?       @db.ObjectId
  itemId               String? // external item reference (e.g., from return flow)
  cosmeticScore        Int // 1-100, 100 = pristine
  conditionLabel       String // "Like New", "Good", "Acceptable", "For Parts/Refurb Only"
  conditionTier        ConditionTier
  defectHeatmap        String? // base64-encoded PNG overlay
  skuMatchConfidence   Float // 0.0-1.0, CLIP cosine similarity
  isUnusedVerified     Boolean       @default(false) // Module 4a gate: score >= 95 + fraud pass
  manualReviewRequired Boolean       @default(false)
  functionalScore      Float? // From questionnaire (Module 8b)
  finalConditionScore  Int? // Combined cosmetic + functional
  modelVersion         String        @default("dinov2-base+clip-vit-base-patch32-v1")
  captureTemplateUsed  String? // Category-specific template ID
  images               String[] // base64 or URLs of graded images
  product              Product       @relation(fields: [productId], references: [id])
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

// Module 4a — Digital Inventory & Instant Reuse
// Holds unused items virtually until matched to a new buyer (Rahul scenario)
model DigitalInventoryItem {
  id                     String                 @id @default(auto()) @map("_id") @db.ObjectId
  productId              String                 @db.ObjectId
  skuId                  String // exact SKU identifier
  variant                String // size + color (e.g., "size_10_black")
  status                 DigitalInventoryStatus @default(AVAILABLE)
  isUnusedVerified       Boolean                @default(true)
  cosmeticScore          Int // from PHC at time of listing
  originalOwnerId        String                 @db.ObjectId
  matchedBuyerId         String?                @db.ObjectId
  phcId                  String?                @db.ObjectId // reference to ProductHealthCard
  refundIssuedAt         DateTime? // instant refund timestamp
  matchedAt              DateTime? // when matched to new buyer
  logisticsJobId         String? // combined pickup-redeliver job reference
  pendingWindowExpiresAt DateTime? // max hold time (1-14 days)
  product                Product                @relation(fields: [productId], references: [id])
  originalOwner          User                   @relation("DigitalInventoryOriginalOwner", fields: [originalOwnerId], references: [id])
  matchedBuyer           User?                  @relation("DigitalInventoryMatchedBuyer", fields: [matchedBuyerId], references: [id])
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

// Module 6+9 — Green Credits Ledger
// Tracks all carbon-credit transactions: earning (donate/recycle/resale) + redemption
model GreenCreditsLedger {
  id                     String                     @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String                     @db.ObjectId
  transactionId          String                     @unique // e.g., "txn_user_001_0001"
  type                   GreenCreditTransactionType
  role                   String // "seller" | "buyer" | "donor"
  creditsAwarded         Int // positive for earn, negative for redeem
  deltaCo2eKg            Float // kg CO2e avoided (0 for redemptions)
  skuId                  String? // product category reference
  category               String? // product category for emission lookup
  bonusMultiplierApplied Float? // 1.3x for refurbished redemption
  discountValue          Float? // ₹ value of discount (redemption only)
  itemId                 String? // related item/listing
  user                   User                       @relation(fields: [userId], references: [id])
  createdAt              DateTime                   @default(now())
}

// Module 8 — Resale Listing (Akshay/Raghav scenarios)
// Full resale/exchange pipeline: invoice verification + condition grading + pricing
model ResaleListing {
  id                  String              @id @default(auto()) @map("_id") @db.ObjectId
  sellerId            String              @db.ObjectId
  productId           String              @db.ObjectId
  conditionTier       ConditionTier
  cosmeticScore       Int
  functionalScore     Float?
  finalConditionScore Int
  listingPrice        Float? // null if not eligible for resale
  exchangeValue       Float? // offered when buying replacement
  originalPrice       Float // from invoice verification
  depreciationFactor  Float?
  demandAdjustment    Float?              @default(1.0)
  status              ResaleListingStatus @default(PENDING_VERIFICATION)
  recommendation      String // "list" | "exchange" | "donate_recycle"
  invoiceData         Json? // extracted invoice fields
  invoiceVerified     Boolean             @default(false)
  invoiceConfidence   Float?
  ownershipVerified   Boolean             @default(false)
  phcId               String?             @db.ObjectId // link to ProductHealthCard
  buyerId             String?             @db.ObjectId // populated on sale
  commissionRate      Float?              @default(0.12) // 10-15% per PRD Sec 4.1
  payoutStatus        String?             @default("held") // "held" | "released"
  functionalResponses Json? // questionnaire answers
  seller              User                @relation("ResaleListingSeller", fields: [sellerId], references: [id])
  buyer               User?               @relation("ResaleListingBuyer", fields: [buyerId], references: [id])
  product             Product             @relation(fields: [productId], references: [id])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

// Module 11 — Seller Trust Score
// Tracks seller trustworthiness for the resale marketplace
model SellerTrustScore {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String   @unique @db.ObjectId
  trustScore            Float    @default(5.0) // 0-5 scale
  firstAttemptPassRate  Float    @default(1.0) // % listings passing verification first try
  resaleReturnRate      Float    @default(0.0) // % of resale items returned by buyers
  totalTransactions     Int      @default(0)
  disputes              Int      @default(0)
  accountTenureDays     Int      @default(0)
  verificationStatus    String   @default("unverified") // "unverified" | "verified" | "suspended"
  listingReviewRequired Boolean  @default(true) // true for low-trust sellers
  user                  User     @relation(fields: [userId], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
